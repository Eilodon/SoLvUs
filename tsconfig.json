{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "moduleResolution": "node",
    "baseUrl": "./",
    "paths": {
      "@solvus/*": ["packages/*"]
    },
    "outDir": "./dist",
    "rootDir": "./"
  },
  "include": ["packages/**/*", "phase0/**/*"],
  "exclude": ["node_modules", "dist"]
}
